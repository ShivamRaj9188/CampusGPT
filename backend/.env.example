# ============================================================
# CampusGPT — Environment Variable Template
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ============================================================

# ─── Database ────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/campusgpt
DB_USERNAME=postgres
DB_PASSWORD=your_secure_database_password_here

# ─── JWT Secret ──────────────────────────────────────────────
# Generate with: openssl rand -base64 64
# Must be at least 32 characters (256 bits) for HS256 signing
# ROTATE THIS KEY if compromised — all sessions will be invalidated
JWT_SECRET=replace-this-with-a-random-64-char-secret-generated-by-openssl
JWT_EXPIRATION=86400000   # 24h in ms — use 3600000 (1h) in production

# ─── Ollama (Local LLM) ───────────────────────────────────────
# Default: http://localhost:11434 (local Ollama installation)
# Change if Ollama is hosted on a remote machine
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ─── Upload Limits ────────────────────────────────────────────
MAX_UPLOAD_SIZE=20MB

# ─── Rate Limiting ────────────────────────────────────────────
RL_PUBLIC_CAPACITY=10      # requests per window for /auth/** endpoints
RL_PUBLIC_REFILL=1         # window in minutes (refill period)
RL_AUTH_CAPACITY=60        # requests per window for authenticated endpoints
RL_AUTH_REFILL=1

# ─── Logging ──────────────────────────────────────────────────
# Use INFO in staging/prod, DEBUG only in local dev
LOG_LEVEL=INFO
